FLASK_SECRET_KEY=change-me
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/absolute/path/to/google-client-secret.json
TEAM_PORTAL_HOST=127.0.0.1
TEAM_PORTAL_PORT=5000
# For team deployment through Cloudflare Tunnel, set this to the public hostname, for example:
# TEAM_PORTAL_BASE_URL=https://jira-tool.example.com
TEAM_PORTAL_BASE_URL=
# Live tunnel provider. Use cloudflare for Cloudflare Tunnel; ngrok remains available for rollback.
TEAM_PORTAL_TUNNEL_PROVIDER=cloudflare
TEAM_PORTAL_CLOUDFLARE_TUNNEL_NAME=bankpmtool-live
# Use http2 by default because some corporate/VPN networks block QUIC UDP.
TEAM_PORTAL_CLOUDFLARE_PROTOCOL=http2
# Required for non-interactive Cloud Run releases. Do not rely on a personal gcloud login for deploys.
GOOGLE_CLOUD_PROJECT=
CLOUD_RUN_DEPLOY_ACCOUNT=
# Set to uat only for Cloud Run tagged UAT revisions. Leave blank for Live.
TEAM_PORTAL_STAGE=
# UAT deploys pin this to the tested Git commit so /healthz shows the candidate revision.
TEAM_PORTAL_RELEASE_REVISION=
# If TEAM_PORTAL_TUNNEL_PROVIDER=ngrok and TEAM_PORTAL_BASE_URL points to an ngrok URL,
# the bundled ngrok scripts can reuse it directly.
# Optional: specific Google emails allowed to use the portal.
# TEAM_ALLOWED_EMAILS=alice@npt.sg,bob@npt.sg
TEAM_ALLOWED_EMAILS=
# Shared team mode: allow any NPT Google account.
TEAM_ALLOWED_EMAIL_DOMAINS=npt.sg
# TEAM_PORTAL_DATA_DIR=/absolute/path/to/team-portal-data
TEAM_PORTAL_DATA_DIR=.team-portal
# Required when teammates save BPMIS tokens in the shared portal.
# Generate with:
# python3 - <<'PY'
# from cryptography.fernet import Fernet
# print(Fernet.generate_key().decode())
# PY
TEAM_PORTAL_CONFIG_ENCRYPTION_KEY=

# Optional Trello sync for SeaTalk Daily Email follow-up cards.
TRELLO_API_KEY=
TRELLO_API_TOKEN=
TRELLO_BOARD_ID=
TRELLO_DAILY_LIST_NAME=Daily Summary Email

SPREADSHEET_ID=
COMMON_TAB_NAME=Common
INPUT_TAB_NAME=Sheet1

# Optional OAuth callback override if needed by your Google app config.
# GOOGLE_OAUTH_REDIRECT_URI=https://jira-tool.example.com/auth/google/callback

# API-first BPMIS integration
BPMIS_BASE_URL=https://bpmis-uat1.uat.npt.seabank.io
# Cloud Run first assumes BPMIS is directly reachable from GCP.
# Use local_agent on Cloud Run when BPMIS is only reachable through the Mac VPN.
BPMIS_CALL_MODE=local_agent
# Optional fallback for local mode only. In shared mode, teammates save their own token in the portal.
# BPMIS_API_ACCESS_TOKEN=

# Mac local-agent bridge used after Cloud Run deployment for capabilities that must stay on the Mac.
# For Mac-hosted Live, keep LOCAL_AGENT_BASE_URL on loopback so the portal calls the local-agent directly.
# Cloud Run UAT/backup can use TEAM_PORTAL_BASE_URL as the public proxy for /api/local-agent/*.
LOCAL_AGENT_MODE=disabled
LOCAL_AGENT_BASE_URL=
LOCAL_AGENT_HMAC_SECRET=
LOCAL_AGENT_TIMEOUT_SECONDS=300
LOCAL_AGENT_SOURCE_CODE_QA_ENABLED=false
LOCAL_AGENT_SEATALK_ENABLED=false
LOCAL_AGENT_BPMIS_ENABLED=true
LOCAL_AGENT_HOST=127.0.0.1
LOCAL_AGENT_PORT=7007
LOCAL_AGENT_PUBLIC_URL=

# PRD briefing portal: Confluence
# Use email + API token for Atlassian Cloud, or a bearer token if your org provides one.
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_BEARER_TOKEN=

# Shared Codex model routing. Reasoning effort is passed to Codex CLI as model_reasoning_effort.
CODEX_MODEL_CHEAP=gpt-5.4-mini
CODEX_MODEL_BALANCED=gpt-5.4
CODEX_MODEL_DEEP=gpt-5.5
CODEX_MODEL_COMPACT_DEEP=gpt-5.4
CODEX_MODEL_REPAIR=gpt-5.5
CODEX_REASONING_CHEAP=low
CODEX_REASONING_BALANCED=medium
CODEX_REASONING_DEEP=high
CODEX_REASONING_COMPACT_DEEP=medium
CODEX_REASONING_REPAIR=high

# PRD briefing portal: Codex + Edge TTS
# Optional legacy override. Leave blank to use CODEX_MODEL_BALANCED.
PRD_BRIEFING_CODEX_MODEL=
SEATALK_CODEX_MODEL=
PRD_BRIEFING_EDGE_MANDARIN_VOICE=zh-CN-XiaoxiaoNeural
PRD_BRIEFING_EDGE_ENGLISH_VOICE=en-SG-LunaNeural
PRD_BRIEFING_EDGE_MANDARIN_RATE=+0%
PRD_BRIEFING_EDGE_ENGLISH_RATE=-5%
PRD_BRIEFING_EDGE_RATE=-12%

# Meeting Recorder uses the local ScreenCaptureKit helper for system audio + microphone capture.
# Daily host storage maintenance compresses Meeting Recorder raw .caf files
# older than 3 days and removes stale Source Code QA index temp files.
TEAM_PORTAL_STORAGE_MAINTENANCE_ENABLED=1
TEAM_PORTAL_STORAGE_MAINTENANCE_INTERVAL_SECONDS=86400
MEETING_RECORDER_TRANSCRIPT_SEGMENT_WORKERS=2
MEETING_RECORDER_WHISPER_THREADS=0
MEETING_RECORDER_BACKGROUND_NICE=10
MEETING_RECORDER_CAPTURE_STATUS_EVERY_BUFFERS=250
MEETING_RECORDER_STARTUP_SILENCE_GRACE_SECONDS=300

# Source Code Q&A: repository sync and Codex-only answer generation.
SOURCE_CODE_QA_GITLAB_TOKEN=
SOURCE_CODE_QA_GITLAB_USERNAME=oauth2
SOURCE_CODE_QA_LLM_PROVIDER=codex_cli_bridge
SOURCE_CODE_QA_CODEX_BINARY=codex
# Optional legacy override for all Source Code Q&A Codex routes. Leave blank to use the route-specific model ladder.
SOURCE_CODE_QA_CODEX_MODEL=
SOURCE_CODE_QA_CODEX_MODEL_CHEAP=gpt-5.4-mini
SOURCE_CODE_QA_CODEX_MODEL_BALANCED=gpt-5.4
SOURCE_CODE_QA_CODEX_MODEL_DEEP=gpt-5.5
SOURCE_CODE_QA_CODEX_MODEL_COMPACT_DEEP=gpt-5.4
SOURCE_CODE_QA_CODEX_MODEL_REPAIR=gpt-5.5
SOURCE_CODE_QA_CODEX_REASONING_CHEAP=low
SOURCE_CODE_QA_CODEX_REASONING_BALANCED=medium
SOURCE_CODE_QA_CODEX_REASONING_DEEP=high
SOURCE_CODE_QA_CODEX_REASONING_COMPACT_DEEP=medium
SOURCE_CODE_QA_CODEX_REASONING_REPAIR=high
# Optional role-specific model overrides. Leave blank to use the provider's fast/balanced/deep defaults.
SOURCE_CODE_QA_QUERY_REWRITE_MODEL=
SOURCE_CODE_QA_PLANNER_MODEL=
SOURCE_CODE_QA_ANSWER_MODEL=
SOURCE_CODE_QA_REPAIR_MODEL=
SOURCE_CODE_QA_LLM_TIMEOUT_SECONDS=90
SOURCE_CODE_QA_CODEX_TIMEOUT_SECONDS=360
SOURCE_CODE_QA_QUERY_DEADLINE_SECONDS=360
SOURCE_CODE_QA_CODEX_REPAIR_DEADLINE_SECONDS=300
SOURCE_CODE_QA_EMBEDDING_MODEL=local-token-hybrid-v1
SOURCE_CODE_QA_SEMANTIC_INDEX_ENABLED=true
SOURCE_CODE_QA_LLM_CACHE_TTL_SECONDS=1800
SOURCE_CODE_QA_CODEX_CONCURRENCY=2
