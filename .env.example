FLASK_SECRET_KEY=change-me
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/absolute/path/to/google-client-secret.json
TEAM_PORTAL_HOST=127.0.0.1
TEAM_PORTAL_PORT=5000
# For team deployment through Cloudflare Tunnel, set this to the public hostname, for example:
# TEAM_PORTAL_BASE_URL=https://jira-tool.example.com
TEAM_PORTAL_BASE_URL=
# If TEAM_PORTAL_BASE_URL points to an ngrok URL, the bundled ngrok scripts can reuse it directly.
# Optional: specific Google emails allowed to use the portal.
# TEAM_ALLOWED_EMAILS=alice@npt.sg,bob@npt.sg
TEAM_ALLOWED_EMAILS=
# Shared team mode: allow any NPT Google account.
TEAM_ALLOWED_EMAIL_DOMAINS=npt.sg
# TEAM_PORTAL_DATA_DIR=/absolute/path/to/team-portal-data
TEAM_PORTAL_DATA_DIR=.team-portal
# Required when teammates save BPMIS tokens in the shared portal.
# Generate with:
# python3 - <<'PY'
# from cryptography.fernet import Fernet
# print(Fernet.generate_key().decode())
# PY
TEAM_PORTAL_CONFIG_ENCRYPTION_KEY=
SPREADSHEET_ID=1KKlqDosv2QjCZrY8If-JreuVa_ALHZUIrxhMbAa_y_Q
COMMON_TAB_NAME=Common
INPUT_TAB_NAME=Sheet1

# Optional OAuth callback override if needed by your Google app config.
# GOOGLE_OAUTH_REDIRECT_URI=https://jira-tool.example.com/auth/google/callback

# API-first BPMIS integration
BPMIS_BASE_URL=https://bpmis-uat1.uat.npt.seabank.io
# Cloud Run first assumes BPMIS is directly reachable from GCP.
# Use local_agent on Cloud Run when BPMIS is only reachable through the Mac VPN.
BPMIS_CALL_MODE=local_agent
# Optional fallback for local mode only. In shared mode, teammates save their own token in the portal.
# BPMIS_API_ACCESS_TOKEN=

# Mac local-agent bridge used after Cloud Run deployment for capabilities that must stay on the Mac.
# LOCAL_AGENT_BASE_URL should be the fixed ngrok URL for scripts/run_local_agent_tunnel.sh.
LOCAL_AGENT_MODE=disabled
LOCAL_AGENT_BASE_URL=
LOCAL_AGENT_HMAC_SECRET=
LOCAL_AGENT_TIMEOUT_SECONDS=300
LOCAL_AGENT_SOURCE_CODE_QA_ENABLED=false
LOCAL_AGENT_SEATALK_ENABLED=false
LOCAL_AGENT_BPMIS_ENABLED=true
LOCAL_AGENT_HOST=127.0.0.1
LOCAL_AGENT_PORT=7007
LOCAL_AGENT_PUBLIC_URL=

# PRD briefing portal: Confluence
# Use email + API token for Atlassian Cloud, or a bearer token if your org provides one.
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_BEARER_TOKEN=

# PRD briefing portal: OpenAI
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
PRD_BRIEFING_TEXT_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
PRD_BRIEFING_GEMINI_TEXT_MODEL=gemini-2.5-flash
PRD_BRIEFING_TEXT_PROVIDER_PRIORITY=gemini_first
PRD_BRIEFING_EMBEDDING_MODEL=text-embedding-3-large
PRD_BRIEFING_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
PRD_BRIEFING_TTS_MODEL=gpt-4o-mini-tts
PRD_BRIEFING_TTS_PROVIDER=edge
PRD_BRIEFING_EDGE_MANDARIN_VOICE=zh-CN-XiaoxiaoNeural
PRD_BRIEFING_EDGE_ENGLISH_VOICE=en-US-JennyNeural
PRD_BRIEFING_EDGE_RATE=-8%
PRD_BRIEFING_OPENAI_DEFAULT_VOICE=alloy
PRD_BRIEFING_OPENAI_CUSTOM_VOICE_ENABLED=false
PRD_BRIEFING_ANSWER_AUDIO_ENABLED=false

