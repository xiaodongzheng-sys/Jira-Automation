[run]
# This is the 100% governed coverage surface for the release gate. Broader
# module coverage is still tracked as an advisory baseline, but only code listed
# here is allowed to block releases at 100%.
include =
    bpmis_jira_tool/config.py
    bpmis_jira_tool/errors.py
    bpmis_jira_tool/user_config.py
    prd_briefing/models.py
    prd_briefing/text_generation.py
omit =
    tests/*
    .venv/*
    .team-portal/*
    .team-portal-uat/*

[report]
fail_under = 100
show_missing = True
skip_covered = False
exclude_also =
    if __name__ == "__main__":
    if TYPE_CHECKING:
